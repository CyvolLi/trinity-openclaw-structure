ocal/lib/node_modules/openclaw/docs/gateway/doctor.md\n/usr/local/lib/node_modules/openclaw/docs/gateway/config-tools.md\n/usr/local/lib/node_modules/openclaw/docs/gateway/configuration-examples.md\n/usr/local/lib/node_modules/openclaw/docs/gateway/configuration-reference.md\n/usr/local/lib/node_modules/openclaw/docs/gateway/configuration.md\n/usr/local/lib/node_modules/openclaw/docs/gateway/bonjour.md\n/usr/local/lib/node_modules/openclaw/docs/gateway/security/audit-checks.md\n/usr/local/lib/node_modules/openclaw/docs/gateway/security/index.md","cwd":"/root/.openclaw/workspace-father"},"isError":false,"timestamp":1779990257861}}
