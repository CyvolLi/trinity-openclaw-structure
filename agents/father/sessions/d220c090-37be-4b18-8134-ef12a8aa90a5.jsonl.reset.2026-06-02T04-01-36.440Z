{"type":"message","id":"43b4fc27","parentId":"ba6930aa","timestamp":"2026-06-01T02:15:50.670Z","message":{"role":"toolResult","toolCallId":"call_00_OxpLMQ55NwOaUVuOkokg7795","toolName":"exec","content":[{"type":"text","text":"{\"0\":\"{\\\"subsystem\\\":\\\"channels/qqbot\\\"}\",\"1\":\"[bot2] [qqbot:api] <<< Status: 200 OK | TraceId: 244c54bf5ed2caca48663270adc04575\",\"_meta\":{\"runtime\":\"node\",\"runtimeVersion\":\"22.22.1\",\"hostname\":\"unknown\",\"name\":\"{\\\"subsystem\\\":\\\"channels/qqbot\\\"}\",\"parentNames\":[\"openclaw\"],\"date\":\"2026-06-01T02:15:21.674Z\",\"logLevelId\":3,\"logLevelName\":\"INFO\",\"path\":{\"fullFilePath\":\"file:///usr/local/lib/node_modules/openclaw/dist/subsystem-DmpKP7hZ.js:179:14\",\"fileName\":\"subsystem-DmpKP7hZ.js\",\"fileNameWithLine\":\"subsystem-DmpKP7hZ.js:179\",\"fileColumn\":\"14\",\"fileLine\":\"179\",\"filePath\":\"/usr/local/lib/node_modules/openclaw/dist/subsystem-DmpKP7hZ.js\",\"filePathWithLine\":\"/usr/local/lib/node_modules/openclaw/dist/subsystem-DmpKP7hZ.js:179\",\"method\":\"logToFile\"}},\"time\":\"2026-06-01T10:15:21.675+08:00\",\"hostname\":\"iZwz9fsb7hxrqc27t9an22Z\",\"message\":\"[bot2] [qqbot:api] <<< Status: 200 OK | TraceId: 244c54bf5ed2caca48663270adc04575\",\"traceId\":\"3c90ff7795978f6fd35bc4c8b39fd7dd\",\"spanId\":\"9706eac6d0f639c0\",\"traceFlags\":\"01\"}"}],"details":{"status":"completed","exitCode":0,"durationMs":430,"aggregated":"{\"0\":\"{\\\"subsystem\\\":\\\"channels/qqbot\\\"}\",\"1\":\"[bot2] [qqbot:api] <<< Status: 200 OK | TraceId: 244c54bf5ed2caca48663270adc04575\",\"_meta\":{\"runtime\":\"node\",\"runtimeVersion\":\"22.22.1\",\"hostname\":\"unknown\",\"name\":\"{\\\"subsystem\\\":\\\"channels/qqbot\\\"}\",\"parentNames\":[\"openclaw\"],\"date\":\"2026-06-01T02:15:21.674Z\",\"logLevelId\":3,\"logLevelName\":\"INFO\",\"path\":{\"fullFilePath\":\"file:///usr/local/lib/node_modules/openclaw/dist/subsystem-DmpKP7hZ.js:179:14\",\"fileName\":\"subsystem-DmpKP7hZ.js\",\"fileNameWith