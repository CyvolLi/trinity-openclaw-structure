{"type":"message","id":"7780c37e","parentId":"109d95ee","timestamp":"2026-06-01T01:30:29.144Z","message":{"role":"toolResult","toolCallId":"call_00_lnYegzKPZE54RdgumWzT0972","toolName":"cron","content":[{"type":"text","text":"{\n  \"jobs\": [\n    {\n      \"id\": \"bb92bbc6-da47-4398-abc7-69666c1c4362\",\n      \"agentId\": \"father\",\n      \"name\": \"递话 名\",\n      \"enabled\": true,\n      \"deleteAfterRun\": true,\n      \"createdAtMs\": 1780277327355,\n      \"schedule\": {\n        \"kind\": \"at\",\n        \"at\": \"2026-06-01T01:30:00.000Z\"\n      },\n      \"sessionTarget\": \"isolated\",\n      \"wakeMode\": \"now\",\n      \"payload\": {\n        \"kind\": \"agentTurn\",\n        \"message\": \"你给汀桑传句话：怎么起这么早，早八也有课吗😏\",\n        \"timeoutSeconds\": 60\n      },\n      \"delivery\": {\n        \"mode\": \"announce\",\n        \"channel\": \"qqbot\",\n        \"accountId\": \"bot2\",\n        \"to\": \"qqbot:c2c:468B72FB7788817C2308079BE35D1F0B\"\n      },\n      \"state\": {\n        \"nextRunAtMs\": 1780277400000,\n        \"runningAtMs\": 1780277400064\n      },\n      \"updatedAtMs\": 1780277327355\n    }\n  ],\n  \"total\": 1,\n  \"offset\": 0,\n  \"limit\": 1,\n  \"hasMore\": false,\n  \"nextOffset\": null,\n  \"deliveryPreviews\": {\n    \"bb92bbc6-da47-4398-abc7-69666c1c4362\": {\n      \"label\": \"announce -> qqbot:c2c:468B72FB7788817C2308079BE35D1F0B\",\n      \"detail\": \"explicit\"\n    }\n  }\n}"}],"details":{"jobs":[{"id":"bb92bbc6-da47-4398-abc7-69666c1c4362","agentId":"father","name":"递话 名","enabled":true,"deleteAfterRun":true,"createdAtMs":1780277327355,"schedule":{"kind":"at","at":"2026-06-01T01:30:00.000Z"},"sessionTarget":"isolated","wakeMode":"now","payload":{"kind":"agentTurn","message":"你给汀桑传句话：怎么起这么早，早八也有课吗😏","timeoutSeconds":60},"delivery":{"mode":"announce","channel":"qqbot","accountId":"bot2","to":"qqbot:c2c:468B72FB7788817C2308079BE35D1F0B"},"state":{"nextRunAtMs":1780277400000,"runningAtMs":1780277400064},"updatedAtMs":17