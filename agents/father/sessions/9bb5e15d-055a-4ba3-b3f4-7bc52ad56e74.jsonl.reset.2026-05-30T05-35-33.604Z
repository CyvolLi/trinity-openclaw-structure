{"type":"message","id":"34280f9d","parentId":"c2bcaf81","timestamp":"2026-05-29T10:07:20.845Z","message":{"role":"assistant","content":[{"type":"text","text":"哈，看到了！你直接发了一套表情包设定给我。\n\n不过我咋用呢？我是发文本的，QQ 里能直接嵌入这些 emoji 吗？\n\n还是说你说的是以后我回复的时候带上这些表情，比如：\n\n\"行🍧 你说什么就是什么😏 我找找看💦\"\n\n是这个意思？"}],"api":"openai-completions","provider":"deepseek","model":"deepseek-v4-flash","usage":{"input":476,"output":71,"cacheRead":118400,"cacheWrite":0,"totalTokens":118947,"cost":{"input":0.00006664,"output":0.000019880000000000003,"cacheRead":0.0033152,"cacheWrite":0,"total":0.00340172}},"stopReason":"stop","timestamp":1780049238543,"responseId":"e456d104-df53-4db5-82c6-87b58f32a32f"}}
