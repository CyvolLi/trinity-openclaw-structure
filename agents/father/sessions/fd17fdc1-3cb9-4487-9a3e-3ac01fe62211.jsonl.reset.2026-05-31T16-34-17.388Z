{"type":"message","id":"69a27eaf","parentId":"32789369","timestamp":"2026-05-31T06:12:07.959Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"汀桑说改，那我就直接改了。早朝 cron 的 timeoutSeconds 从 120 改到 300。","thinkingSignature":"reasoning_content"},{"type":"toolCall","id":"call_00_LrNCbDlKJSEf8S2oh4uo2173","name":"cron","arguments":{"action":"update","jobId":"557cdce4-3315-41d0-a7c9-37f069050678","patch":{"payload":{"kind":"agentTurn","message":"[morningcourt] sender_id=6687D4D2D1F8EDA5231C6809B1A26204, trigger briefing generation","timeoutSeconds":300}}},"partialArgs":"{\"action\": \"update\", \"jobId\": \"557cdce4-3315-41d0-a7c9-37f069050678\", \"patch\": {\"payload\": {\"kind\": \"agentTurn\", \"message\": \"[morningcourt] sender_id=6687D4D2D1F8EDA5231C6809B1A26204, trigger briefing generation\", \"timeoutSeconds\": 300}}}"}],"api":"openai-completions","provider":"deepseek","model":"deepseek-v4-flash","usage":{"input":6339,"output":176,"cacheRead":20352,"cacheWrite":0,"reasoningTokens":26,"totalTokens":26867,"cost":{"input":0.0008874600000000001,"output":0.00004928,"cacheRead":0.000569856,"cacheWrite":0,"total":0.001506596}},"stopReason":"toolUse","timestamp":1780207926274,"responseId":"9242a108-c993-40d6-8d7f-392e3fd5f8af"}}
{"type":"message","id":"5d108f27","parentId":"69a27eaf","timestamp":"2026-05-31T06:12:08.651Z","message":{"role":"toolResult","toolCallId":"call_00_LrNCbDlKJSEf8S2oh4uo2173","toolName":"cron","content":[{"type":"text","text":"{\n  \"id\": \"557cdce4-3315-41d0-a7c9-37f069050678\",\n  \"agentId\": \"son\",\n  \"sessionKey\": \"agent:father:qqbot:direct:6687d4d2d1f8eda5231c6809b1a26204\",\n  \"name\": \"morningcourt-6687D4D2D1F8EDA5231C6809B1A26204\",\n  \"enabled\": true,\n  \"createdAtMs\": 1779997894311,\n  \"schedule\": {\n    \"kind\": \"cron\",\n    \"expr\": \"0 8 * * *\",\n    \"tz\": \"Asia/Shanghai\"\n  },\n  \"sessionTarget\": \"isolated\",\n  \"wakeMode\": \"now\",\n  \"payload\": {\n    \"kind\": \"agentTurn\",\n    \"message\": \"[morningcourt] sender_id=6687D4D2D1F8EDA5231C6809B1A26204, trigger briefing generation\",\n    \"timeoutSeconds\": 300\n  },\n  \"delivery\": {\n    \"mode\": \"announce\",\n    \"channel\": \"qqbot\",\n    \"to\": \"qqbot:c2c:6687D4D2D1F8EDA5231C6809B1A26204\",\n    \"accountId\": \"bot1\"\n  },\n  \"state\": {\n    \"nextRunAtMs\": 1780272000000,\n    \"lastRunAtMs\": 1780185600025,\n    \"lastRunStatus\": \"error\",\n    \"lastStatus\": \"error\",\n    \"lastDurationMs\": 122761,\n    \"lastDeliveryStatus\": \"unknown\",\n    \"lastFailureNotificationDeliveryStatus\": \"unknown\",\n    \"consecutiveErrors\": 1,\n    \"consecutiveSkipped\": 0,\n    \"lastError\": \"cron: job execution timed out (last phase: model-call-started)\",\n    \"lastDiagnostics\": {\n      \"summary\": \"cron: job execution timed out (last phase: model-call-started)\",\n      \"entries\": [\n        {\n          \"ts\": 1780185722785,\n          \"source\": \"cron-setup\",\n          \"severity\": \"error\",\n          \"message\": \"cron: job execution timed out (last phase: model-call-started)\"\n        }\n      ]\n    },\n    \"lastDiagnosticSummary\": \"cron: job execution timed out (last phase: model-call-started)\",\n    \"lastErrorReason\": \"ti