ull key: [$MINIMAX_API_KEY]\\\"\\necho \\\"Length: ${#MINIMAX_API_KEY} chars\\\"\\n# Let me also test by copying the exact key value to a variable and testing\\nKEY=\\\"$MINIMAX_API_KEY\\\"\\ncurl -s --max-time 10 -X POST \\\\\\n  \\\"https://api.minimaxi.com/v1/music_generation\\\" \\\\\\n  -H \\\"Authorization: Bearer $KEY\\\" \\\\\\n  -H \\\"Content-Type: application/json\\\" \\\\\\n  -d '{}' 2>&1\", \"timeout\": 15}"}],"api":"openai-completions","provider":"deepseek","model":"deepseek-v4-flash","usage":{"input":331,"output":719,"cacheRead":143616,"cacheWrite":0,"reasoningTokens":531,"totalTokens":144666,"cost":{"input":0.00004634,"output":0.00020132,"cacheRead":0.004021248,"cacheWrite":0,"total":0.004268908}},"stopReason":"toolUse","timestamp":1780231583165,"responseId":"148dade7-6397-431e-a81b-72dd4f3dd2ca"}}
