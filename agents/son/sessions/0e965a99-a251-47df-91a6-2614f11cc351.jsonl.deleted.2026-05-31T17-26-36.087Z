{"type":"message","id":"54e3f30c","parentId":"871e2aed","timestamp":"2026-05-31T17:26:30.124Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"Let me read the generate.py script to understand what it does, then run it with 114514.","thinkingSignature":"reasoning_content"},{"type":"toolCall","id":"call_00_hGFleI2qmxwYBvWl1lgQ3162","name":"read","arguments":{"path":"~/.openclaw/workspace-son/stench_number/generate.py"},"partialArgs":"{\"path\": \"~/.openclaw/workspace-son/stench_number/generate.py\"}"}],"api":"openai-completions","provider":"deepseek","model":"deepseek-v4-flash","usage":{"input":145,"output":80,"cacheRead":13312,"cacheWrite":0,"reasoningTokens":21,"totalTokens":13537,"cost":{"input":0.000020300000000000002,"output":0.000022400000000000002,"cacheRead":0.000372736,"cacheWrite":0,"total":0.000415436}},"stopReason":"toolUse","timestamp":1780248388551,"responseId":"550dbad8-c757-41e1-b6b2-ae03898ca551"}}
{"type":"message","id":"6f1c3ec1","parentId":"54e3f30c","timestamp":"2026-05-31T17:26:30.200Z","message":{"role":"toolResult","toolCallId":"call_00_hGFleI2qmxwYBvWl1lgQ3162","toolName":"read","content":[{"type":"text","text":"#!/usr/bin/env python3\n\"\"\"\n数字恶臭化生成器 — 通用搜索版 (v3)\n====================================\n使用 114514 系列数字池，通过通用 DFS/DP 搜索算法，\n自动拆解任意目标数字为恶臭风格数学表达式。\n\n约束：不产生值为 0 的中间结果。表达式中的数字尽量不含 0 数码位。\n运算符只用 + − × ÷，不出现 −− 双负号。\n\n搜索策略：\n  A - 直接加法分解（纯正数之和）\n  B - 114514 × k + r（基础乘法拆解，k 和 r 都分解）\n  C - 1145140 × k + r（大数乘法拆解）\n  D - 514 × a + 114 × b + r（双臭混合）\n  E - 14514 × k + r（近亲乘法变体）\n  F - 除法还原：(a × b) ÷ c + r \n  G - 114514 进制展开（学院派）\n\n用法：\n    python3 generate.py <数字>\n    python3 generate.py 20070521\n\n灵感源自 lab.magiconch.com 的数字恶臭化工具。\n\"\"\"\n\nimport sys\nimport re\nimport math\nfrom functools import lru_cache\n\n# =====================================================================\n# 第一节：恶臭数字池\n# =====================================================================\n\n# 基础数集（不含 0 数码位）\nBASE_POOL = [1, 4, 5, 11, 14, 15, 51, 54]\n# 扩展数集（不含 0 数码位）\nEXT_POOL = [114, 514, 1145, 1451, 14514, 114514]\n# 巨型数（含 0 数码位的超级数，用于大数场景）\nMEGA_POOL = [1145140, 1919810, 1145141919810]\n\n# 全量池\nALL_POOL = sorted(set(BASE_POOL + EXT_POOL))\nALL_POOL_MEGA = sorted(set(ALL_POOL + MEGA_POOL))\n\n# =====================================================================\n# 第二节：辅助函数\n# =====================================================================\n\ndef has_digit_zero(n):\n    \"\"\"数字的十进制表示中是否含有 0 数码位\"\"\"\n    return '0' in str(abs(n))\n\ndef eval_expr(expr_str):\n    \"\"\"安全计算表达式值（替换 Unicode 数学符号为 ASCII）\"\"\"\n    s = expr_str.replace('×', '*').replace('−', '-').replace('÷', '/')\n    s = s.replace('＋', '+')\n    return eval(s)\n\ndef verify_no_zero_value(expr_str):\n    \"\"\"验证表达式计算不产生零值\"\"\"\n    if re.search(r'(?<!\\d)(\\d+)\\s*−\\s*\\1(?!\\d)', expr_str):\n        return False\n    if '÷ 0' in expr_str or '÷0' in expr_str:\n        return False\n    try:\n        return eval_expr(expr_str) != 0\n    except:\n        return False\n\ndef count_standalone(expr_str, target_num):\n    \"\"\"统计表达式中独立出现 target_num 的次数（非数字前缀）\"\"\"\n    pattern = r'(?<!\\d)' + str(target_num) + r'(?!\\d)'\n    return len(re.findall(pattern, expr_str))\n\ndef terms_sum(terms):\n    \"\"\"计算 [(sign, num), ...] 的代数和\"\"\"\n    return sum(v if s == '+' else -v for s, v in terms)\n\ndef has_any_zero_term(terms):\n    \"\"\"检查是否有值为 0 的项或 a − a 抵消\"\"\"\n    for s, v in terms:\n        if v == 0:\n            return True\n    net = {}\n    for s, v in terms:\n        net[v] = net.get(v, 0) + (1 if s == '+' else -1)\n    return any(c == 0 for c in net.values())\n\ndef terms_to_expr(terms):\n    \"\"\"将 [(sign, num), ...] 转为表达式字符串，连接处无双负号\"\"\"\n    if not terms:\n        return \"\"\n    parts = []\n    for i, (sign, num) in enumerate(terms):\n        if i == 0:\n            if sign == '+':\n                parts.append(str(num))\n            else:\n                parts.append(f\"−{num}\")\n        else:\n            # 如果上一个是 − 结果，这里再 − 就会成 −−，转为 + 来避免\n            prev_end = parts[-1][-1] if parts else ''\n            if sign == '+':\n                parts.append(f\" + {num}\")\n            else:\n                # 前面已经是负号结尾或数字结尾都没问题\n                parts.append(f\" − {num}\")\n    return \"\".join(parts)\n\ndef expr_has_bad_patterns(expr_str):\n    \"\"\"检查表达式是否包含不应出现的模式\"\"\"\n    # ÷ 1\n    if re.search(r'÷\\s*1(?!\\d)', expr_str):\n        return True\n    # × 1\n    if re.search(r'×\\s*1(?!\\d)', expr_str):\n        return True\n    # ÷ 0\n    if re.search(r'÷\\s*0', expr_str):\n        return True\n    # − − (double minus)\n    if '− −' in expr_str or '−−' in expr_str:\n        return True\n    # 数字中含 0 数码位\n    nums = re.findall(r'\\d+', expr_str)\n    for n in nums:\n        if '0' in n:\n            return True\n    return False\n\n# =====================================================================\n# 第三节：核心分解算法（带缓存的 DP + DFS）\n# =====================================================================\n\n@lru_cache(maxsize=10000)\ndef decompose_sum(target, max_terms=8, pool=None):\n    \"\"\"\n    DP/DFS：将 target 分解为 pool 中正数的加法链。\n    返回 [n1, n2, ...] 列表，和为 target。\n    返回 None 表示无解。\n    所有返回的数都不含 0 数码位（除非 pool 本身含 0）。\n    \"\"\"\n    if pool is None:\n        pool_tuple = tuple(ALL_POOL)\n    else:\n        pool_tuple = tuple(sorted(pool))\n\n    target = abs(target)\n    if target == 0:\n        return []\n    if target in pool_tuple:\n        return [target]\n    if max_terms <= 1:\n        return None\n\n    best = None\n    for n in reversed(pool_tuple):\n        if n > target or n == 0:\n            continue\n        rest = decompose_sum(target - n, max_terms - 1, pool_tuple)\n        if rest is not None:\n            cand = [n] + rest\n            if best is None or len(cand) < len(best):\n                best = cand\n            if len(cand) <= 2:\n                return cand\n    return best\n\n\n@lru_cache(maxsize=10000)\ndef decompose_mixed(target, max_terms=6, pool=None):\n    \"\"\"\n    DP/DFS：将 target 分解为 pool 中带符号数的代数和。\n    返回 [(sign, num), ...] 列表，代数和 = target。\n    不允许出现相同值正负相消。\n    返回 None 表示无解。\n    \"\"\"\n    if pool is None:\n        pool_tuple = tuple(ALL_POOL)\n    else:\n        pool_tuple = tuple(sorted(pool))\n\n    target = int(target)\n    if target == 0:\n        return None  # 不允许结果为 0\n    if target in pool_tuple:\n        return [('+', target)]\n    if -target in pool_tuple:\n        return [('-', target)]\n\n    if max_terms <= 1:\n        return None\n\n    best = None\n\n    for n in reversed(pool_tuple):\n        if n == 0:\n            continue\n\n        # 分支 1：n + rest = target → rest = target − n\n        r1 = target - n\n        if abs(r1) > 0:  # 不允许 0\n            rest1 = decompose_mixed(r1, max_terms - 1, pool_tuple)\n            if rest1 is not None:\n                cand = [('+', n)] + rest1\n                if not has_any_zero_term(cand):\n                    if best is None or len(cand) < len(best):\n                        best = cand\n                    if len(cand) <= 2:\n                        return cand\n\n        # 分支 2：−n + rest = target → rest = target + n\n        r2 = target + n\n        if abs(r2) > 0:\n            rest2 = decompose_mixed(r2, max_terms - 1, pool_tuple)\n            if rest2 is not None:\n                cand = [('-', n)] + rest2\n                if not has_any_zero_term(cand):\n                    if best is None or len(cand) < len(best):\n                        best = cand\n\n        # 分支 3：n − rest = target → rest = n − target\n        if n > target:\n            r3 = n - target\n            if r3 > 0:\n                rest3 = decompose_mixed(r3, max_terms - 1, pool_tuple)\n                if rest3 is not None:\n                    cand = [('+', n)]\n                    for s, v in rest3:\n                        cand.append(('-' if s == '+' else '+', v))\n                    if not has_any_zero_term(cand):\n                        if best is None or len(cand) < len(best):\n                            best = cand\n\n        # 分支 4：target = −n + rest, where n > target (n is bigger)\n        # Actually this is same as branch 2\n\n    return best\n\n\ndef decompose_simple_sum(target, max_terms=8):\n    \"\"\"纯正数加法分解，适合用在括号内部。确保不含 0 数码位。\"\"\"\n    result = decompose_sum(target, max_terms)\n    if result is None:\n        return None\n    # 验证不含 0 数码位\n    for n in result:\n        if has_digit_zero(n):\n            return None\n    return result\n\n\ndef sum_decomp_to_expr(terms):\n    \"\"\"将 [n1, n2, ...] 格式化为加法连接\"\"\"\n    if not terms:\n        return \"\"\n    return \" + \".join(str(n) for n in terms)\n\n\n@lru_cache(maxsize=5000)\ndef decompose_remainder(r, max_depth=3):\n    \"\"\"\n    将余数 r 分解为 a × b + c 形式（高级恶臭分解）。\n    返回表达式字符串（不含 0 数码位，不含双负号），或 None。\n    \"\"\"\n    if r <= 0:\n        return None\n\n    # 如果 r 本身不含 0 数码位：作为一级候选\n    if not has_digit_zero(r):\n        # 也在池中？直接返回\n        if r in ALL_POOL:\n            return str(r)\n\n    candidates = []\n    # 限定 a 范围加速：a 不应太大\n    usable_a = [n for n in reversed(ALL_POOL) if n <= r]\n\n    # 方法1: a × b = r （完美匹配）\n    for a in usable_a:\n        for b in ALL_POOL:\n            if b == 0:\n                continue\n            prod = a * b\n            if prod == r:\n                cand = f\"{a} × {b}\"\n                if not expr_has_bad_patterns(cand):\n                    return cand  # 最佳情况\n            if prod > r:\n                break\n\n    # 方法2: a × b + c = r (c ≤ 2000，小修正)\n    if max_depth > 0:\n        for a in usable_a:\n            max_b = min(r // a + 1, 200)\n            for b in ALL_POOL:\n                if b == 0 or b > max_b:\n                    continue\n                prod = a * b\n                if prod >= r:\n                    continue\n                c = r - prod\n                if c > 2000:\n                    continue  # 余数太大，不好\n                if has_digit_zero(c) and max_depth > 1:\n                    c_sub = decompose_remainder(c, max_depth - 1)\n                    if c_sub:\n                        cand = f\"{a} × {b} + {c_sub}\"\n                        if not expr_has_bad_patterns(cand):\n                            candidates.append(cand)\n                elif not has_digit_zero(c):\n                    cand = f\"{a} × {b} + {c}\"\n                    if not expr_has_bad_patterns(cand):\n                        candidates.append(cand)\n\n        # 方法3: a × b − c = r (c ≤ 2000)\n        for a in usable_a:\n            min_b = r // a + 1\n            for b in ALL_POOL:\n                if b == 0 or b < min_b:\n                    continue\n                prod = a * b\n                if prod <= r:\n                    continue\n                c = prod - r\n                if c > 2000:\n                    continue\n                if has_digit_zero(c):\n                    continue\n                cand = f\"{a} × {b} − {c}\"\n                if not expr_has_bad_patterns(cand):\n                    candidates.append(cand)\n\n    # 方法4: 纯加法分解（兜底）\n    if r > 0 and not has_digit_zero(r) and max_depth > 0:\n        s_decomp = decompose_simple_sum(r, max_terms=6)\n        if s_decomp:\n            cand = sum_decomp_to_expr(s_decomp)\n            if not expr_has_bad_patterns(cand):\n                candidates.append(cand)\n\n    if not candidates:\n        return None\n    # 排序：长的优先（更多恶臭数）\n    candidates.sort(key=len, reverse=True)\n    return candidates[0]\n\n\n# =====================================================================\n# 第四节：各搜索策略\n# =====================================================================\n\ndef strategy_A_direct_sum(target):\n    \"\"\"策略 A：直接加减拆解（纯加法链）\"\"\"\n    results = []\n\n    # 如果 target 本身就在池中\n    if target in (ALL_POOL + MEGA_POOL):\n        results.append((str(target), target, \"A0\"))\n        return results\n\n    # A1: 纯加法分解\n    s_decomp = decompose_simple_sum(target, max_terms=8)\n    if s_decomp:\n        expr = sum_decomp_to_expr(s_decomp)\n        if verify_no_zero_value(expr) and not expr_has_bad_patterns(expr):\n            results.append((expr, target, \"A1\"))\n\n    # A2: 用 114 或 514 锚定的加法组合\n    for anchor in [114, 514, 1145, 1451]:\n        if anchor >= target:\n            continue\n        rest = target - anchor\n        s_rest = decompose_simple_sum(rest, max_terms=6)\n        if s_rest:\n            expr = f\"{anchor} + {sum_decomp_to_expr(s_rest)}\"\n            if verify_no_zero_value(expr) and not expr_has_bad_patterns(expr):\n                results.append((expr, target, \"A2\"))\n\n    # A3: 两个锚点\n    anchors_to_try = [(114, 514), (114, 1145), (514, 1145), (514, 1451), (114, 1451)]\n    for a1, a2 in anchors_to_try:\n        if a1 + a2 >= target:\n            continue\n        rest3 = target - a1 - a2\n        s3 = decompose_simple_sum(rest3, max_terms=5)\n        if s3:\n            expr = f\"{a1} + {a2} + {sum_decomp_to_expr(s3)}\"\n            if verify_no_zero_value(expr) and not expr_has_bad_patterns(expr):\n                results.append((expr, target, \"A3\"))\n\n    return results\n\n\ndef strategy_B_114514_mul(target):\n    \"\"\"策略 B：114514 × k + r（基础乘法拆解）\"\"\"\n    if target <= 114514:\n        return []\n\n    results = []\n    base = 114514\n    k = target // base\n    r = target % base\n\n    # ---------- B1: 直接表达 ----------\n    if r == 0:\n        expr = f\"114514 × {k}\"\n        if verify_no_zero_value(expr) and not expr_has_bad_patterns(expr):\n            results.append((expr, target, \"B1\"))\n    else:\n        # 尝试直接写 r\n        if not has_digit_zero(r):\n            expr = f\"114514 × {k} + {r}\"\n            if verify_no_zero_value(expr) and not expr_has_bad_patterns(expr):\n                results.append((expr, target, \"B1\"))\n\n    # ---------- B2: 分解 k（正数加法链）放在括号内 ----------\n    k_decomp = decompose_simple_sum(k, max_terms=5)\n    if k_decomp:\n        k_expr = sum_decomp_to_expr(k_decomp)\n        if r == 0:\n            expr = f\"114514 × ({k_expr})\"\n            if verify_no_zero_value(expr) and not expr_has_bad_patterns(expr):\n                results.append((expr, target, \"B2\"))\n        elif not has_digit_zero(r):\n            expr = f\"114514 × ({k_expr}) + {r}\"\n            if verify_no_zero_value(expr) and not expr_has_bad_patterns(expr):\n                results.append((expr, target, \"B2\"))\n\n    # ---------- B3: 分解 r（使用乘法链）----------\n    if r > 0 and r < base:\n        # B3a: 纯加法分解 r（只用于 r 不含 0 数码位）\n        if not has_digit_zero(r):\n            r_decomp = decompose_simple_sum(r, max_terms=5)\n            if r_decomp:\n                r_expr = sum_decomp_to_expr(r_decomp)\n                expr = f\"114514 × {k} + {r_expr}\"\n                if verify_no_zero_value(expr) and not expr_has_bad_patterns(expr):\n                    results.append((expr, target, \"B3a\"))\n\n        # B3b: 高级分解 r（乘法链，解决含0数码位的问题）\n        r_expr2 = decompose_remainder(r, max_depth=3)\n        if r_expr2:\n            expr_b = f\"114514 × {k} + {r_expr2}\"\n            if verify_no_zero_value(expr_b) and not expr_has_bad_patterns(expr_b):\n                results.append((expr_b, target, \"B3b\"))\n\n        # B3c: k 分解 + r 高级分解\n        kd3c = decompose_simple_sum(k, max_terms=4)\n        if kd3c and r_expr2:\n            k_expr3c = sum_decomp_to_expr(kd3c)\n            expr_c = f\"114514 × ({k_expr3c}) + {r_expr2}\"\n            if verify_no_zero_value(expr_c) and not expr_has_bad_patterns(expr_c):\n                results.append((expr_c, target, \"B3c\"))\n\n        # B3d: k 分解 + r 加法分解（r 无 0 数码位）\n        kd3d = decompose_simple_sum(k, max_terms=4)\n        rd3d = decompose_simple_sum(r, max_terms=4)\n        if kd3d and rd3d and not has_digit_zero(r):\n            expr_d = f\"114514 × ({sum_decomp_to_expr(kd3d)}) + {sum_decomp_to_expr(rd3d)}\"\n            if verify_no_zero_value(expr_d) and not expr_has_bad_patterns(expr_d):\n                results.append((expr_d, target, \"B3d\"))\n\n    # ---------- B4: k−1 和 r+base（获得另一种分解）----------\n    if k > 1:\n        k2 = k - 1\n        r2 = r + base\n\n        # B4a: 直接写 r2（r2可能含0）\n        if not has_digit_zero(r2):\n            expr = f\"114514 × {k2} + {r2}\"\n            if verify_no_zero_value(expr) and not expr_has_bad_patterns(expr):\n                results.append((expr, target, \"B4a\"))\n\n        # B4b: 分解 k2（加法）\n        kd4b = decompose_simple_sum(k2, max_terms=4)\n        if kd4b:\n            k_expr4b = sum_decomp_to_expr(kd4b)\n            if not has_digit_zero(r2):\n                expr = f\"114514 × ({k_expr4b}) + {r2}\"\n                if verify_no_zero_value(expr) and not expr_has_bad_patterns(expr):\n                    results.append((expr, target, \"B4b\"))\n\n        # B4c: 分解 r2（高级分解）\n        r2_expr = decompose_remainder(r2, max_depth=3)\n        if r2_expr:\n            expr4c = f\"114514 × {k2} + {r2_expr}\"\n            if verify_no_zero_value(expr4c) and not expr_has_bad_patterns(expr4c):\n                results.append((expr4c, target, \"B4c\"))\n\n        # B4d: 两者都分解\n        kd4d = decompose_simple_sum(k2, max_terms=3)\n        if kd4d and r2_expr:\n            k_expr4d = sum_decomp_to_expr(kd4d)\n            expr4d = f\"114514 × ({k_expr4d}) + {r2_expr}\"\n            if verify_no_zero_value(expr4d) and not expr_has_bad_patterns(expr4d):\n                results.append((expr4d, target, \"B4d\"))\n\n    return results\n\n\ndef strategy_C_1145140_mul(target):\n    \"\"\"策略 C：1145140 × k + r（大数乘法拆解）\"\"\"\n    if target <= 1145140:\n        return []\n\n    results = []\n    base = 1145140\n    k = target // base\n    r = target % base\n\n    # C1: 直接\n    if r == 0:\n        expr = f\"1145140 × {k}\"\n    else:\n        expr = f\"1145140 × {k} + {r}\"\n    if verify_no_zero_value(expr) and not expr_has_bad_patterns(expr):\n        results.append((expr, target, \"C1\"))\n\n    # C2: 分解 k\n    kd = decompose_simple_sum(k, max_terms=4)\n    if kd:\n        if r == 0:\n            expr = f\"1145140 × ({sum_decomp_to_expr(kd)})\"\n        else:\n            expr = f\"1145140 × ({sum_decomp_to_expr(kd)}) + {r}\"\n        if verify_no_zero_value(expr) and not expr_has_bad_patterns(expr):\n            results.append((expr, target, \"C2\"))\n\n    # C3: 分解 r\n    if r > 0 and r < base:\n        rd = decompose_simple_sum(r, max_terms=5)\n        kd3 = decompose_simple_sum(k, max_terms=3)\n        if kd3 and rd:\n            expr = f\"1145140 × ({sum_decomp_to_expr(kd3)}) + {sum_decomp_to_expr(rd)}\"\n            if verify_no_zero_value(expr) and not expr_has_bad_patterns(expr):\n                results.append((expr, target, \"C3\"))\n\n    return results\n\n\ndef strategy_D_514_114_mix(target):\n    \"\"\"策略 D：514 × a + 114 × b + r（双臭混合）\"\"\"\n    results = []\n\n    # 搜索 a, b 系数\n    max_a = min(target // 514 + 1, 30)\n    for a in range(1, max_a):\n        after_514 = target - 514 * a\n        if after_514 < 0:\n            break\n        max_b = min(after_514 // 114 + 1, 30)\n        for b in range(0, max_b):\n            r = after_514 - 114 * b\n            if r < 0:\n                continue\n            if r > 5000:  # 余数太大就不算了\n                continue\n\n            if r == 0:\n                expr = f\"514 × {a} + 114 × {b}\"\n                if verify_no_zero_value(expr) and not expr_has_bad_patterns(expr):\n                    results.append((expr, target, \"D1\"))\n            else:\n                # 分解 r\n                rd = decompose_simple_sum(r, max_terms=4)\n                if rd:\n                    r_expr = sum_decomp_to_expr(rd)\n\n                    # 无括号版\n                    expr_a = f\"514 × {a} + 114 × {b} + {r_expr}\"\n                    if verify_no_zero_value(expr_a) and not expr_has_bad_patterns(expr_a):\n                        results.append((expr_a, target, \"D2a\"))\n\n            # 尝试分解 a 和 b 本身（放在括号内更臭）\n            if a <= 200 and b <= 200:\n                ad = decompose_simple_sum(a, max_terms=3)\n                bd = decompose_simple_sum(b, max_terms=3)\n                if ad and bd:\n                    a_expr = sum_decomp_to_expr(ad)\n                    b_expr = sum_decomp_to_expr(bd)\n                    r2 = target - 514 * a - 114 * b\n                    if r2 == 0:\n                        expr = f\"514 × ({a_expr}) + 114 × ({b_expr})\"\n                        if verify_no_zero_value(expr) and not expr_has_bad_patterns(expr):\n                            results.append((expr, target, \"D3\"))\n                    elif r2 > 0:\n                        rd3 = decompose_simple_sum(r2, max_terms=3)\n                        if rd3:\n                            expr = f\"514 × ({a_expr}) + 114 × ({b_expr}) + {sum_decomp_to_expr(rd3)}\"\n                            if verify_no_zero_value(expr) and not expr_has_bad_patterns(expr):\n                                results.append((expr, target, \"D3\"))\n\n    return results\n\n\ndef strategy_E_14514_mul(target):\n    \"\"\"策略 E：14514 × k + r（近亲乘法变体）\"\"\"\n    if target <= 14514:\n        return []\n\n    results = []\n    base = 14514\n    k = target // base\n    r = target % base\n\n    # E1\n    if r == 0:\n        expr = f\"14514 × {k}\"\n    else:\n        expr = f\"14514 × {k} + {r}\"\n    if verify_no_zero_value(expr) and not expr_has_bad_patterns(expr):\n        results.append((expr, target, \"E1\"))\n\n    # E2: 分解 k\n    kd = decompose_simple_sum(k, max_terms=4)\n    if kd:\n        if r == 0:\n            expr = f\"14514 × ({sum_decomp_to_expr(kd)})\"\n        else:\n            expr = f\"14514 × ({sum_decomp_to_expr(kd)}) + {r}\"\n        if verify_no_zero_value(expr) and not expr_has_bad_patterns(expr):\n            results.append((expr, target, \"E2\"))\n\n    # E3: 分解 r\n    if r > 0:\n        rd = decompose_simple_sum(r, max_terms=5)\n        kd3 = decompose_simple_sum(k, max_terms=3)\n        if kd3 and rd:\n            expr = f\"14514 × ({sum_decomp_to_expr(kd3)}) + {sum_decomp_to_expr(rd)}\"\n            if verify_no_zero_value(expr) and not expr_has_bad_patterns(expr):\n                results.append((expr, target, \"E3\"))\n\n    return results\n\n\ndef strategy_F_division(target):\n    \"\"\"策略 F：(a × b) ÷ c + r（除法还原）\"\"\"\n    results = []\n\n    multipliers = [114514, 14514, 514, 114]\n    divisors = [n for n in [5, 4, 11, 14, 15, 51, 54, 114, 514] if n != 1]\n\n    for a in multipliers:\n        if a > target * 10:\n            continue\n        for d in divisors:\n            if d == 1 or d == 0:\n                continue\n            # find b such that (a * b) / d is close to target\n            b_approx = target * d // a\n            for b in range(max(1, b_approx - 3), b_approx + 4):\n                prod = a * b\n                if prod % d != 0:\n                    continue\n                val = prod // d\n                if val == target:\n                    expr = f\"({a} × {b}) ÷ {d}\"\n                    if verify_no_zero_value(expr) and not expr_has_bad_patterns(expr):\n                        results.append((expr, target, \"F\"))\n                elif abs(target - val) <= 2000:\n                    r = target - val\n                    if r > 0:\n                        rd = decompose_simple_sum(r, max_terms=3)\n                        if rd:\n                            expr = f\"({a} × {b}) ÷ {d} + {sum_decomp_to_expr(rd)}\"\n                            if verify_no_zero_value(expr) and not expr_has_bad_patterns(expr):\n                                results.append((expr, target, \"F\"))\n\n    return results\n\n\ndef strategy_G_114514_base(target):\n    \"\"\"策略 G：114514 进制展开（学院派）\"\"\"\n    if target < 114514:\n        return []\n\n    results = []\n    base = 114514\n    n = target\n    digits = []\n    while n > 0:\n        d = n % base\n        if d == 0:\n            return []\n        digits.append(d)\n        n //= base\n\n    parts = []\n    ok = True\n    for i, d in enumerate(digits):\n        if has_digit_zero(d):\n            ok = False\n            break\n        if i == 0:\n            parts.append(str(d))\n        elif i == 1:\n            parts.append(f\"{d} × 114514\")\n        else:\n            parts.append(f\"{d} × 114514^{i}\")\n\n    if ok and parts:\n        expr = \" + \".join(reversed(parts))\n        if verify_no_zero_value(expr) and not expr_has_bad_patterns(expr):\n            results.append((expr, target, \"G\"))\n\n    return results\n\n\n# =====================================================================\n# 第五节：搜索编排与结果筛选\n# =====================================================================\n\ndef search_all_strategies(target):\n    \"\"\"运行所有搜索策略，返回去重后的表达式列表\"\"\"\n    all_exprs = []\n    seen = set()\n\n    def add_results(results):\n        for expr, val, strat in results:\n            norm = re.sub(r'\\s+', '', expr)\n            if norm not in seen:\n                seen.add(norm)\n                all_exprs.append((expr, val, strat))\n\n    # 按顺序执行各策略\n    add_results(strategy_A_direct_sum(target))\n    add_results(strategy_B_114514_mul(target))\n    add_results(strategy_D_514_114_mix(target))\n    add_results(strategy_E_14514_mul(target))\n    add_results(strategy_F_division(target))\n    add_results(strategy_G_114514_base(target))\n\n    # 大数补 C\n    if target > 5000000:\n        add_results(strategy_C_1145140_mul(target))\n\n    return all_exprs\n\n\ndef rate_expression(expr_str):\n    \"\"\"\n    评分函数，按 function.md 第 6 节规则。\n    返回 (level, emoji, label, raw_score)\n    \"\"\"\n    score = 0\n\n    # 114 出现次数 (+2 each, max +6)\n    c114 = count_standalone(expr_str, 114)\n    score += min(c114 * 2, 6)\n\n    # 514 出现次数 (+3 each, max +9)\n    c514 = count_standalone(expr_str, 514)\n    score += min(c514 * 3, 9)\n\n    # 114514 完整出现 (+5 each, max +10)\n    c114514 = count_standalone(expr_str, 114514)\n    score += min(c114514 * 5, 10)\n\n    # 运算复杂度\n    has_power = '²' in expr_str or '³' in expr_str or '^' in expr_str\n    score += 3 if has_power else 1\n\n    # 表达式长度（超过 5 个运算符 → +1）\n    ops = sum(1 for c in expr_str if c in '×÷＋−')\n    if ops > 5:\n        score += 1\n\n    # 恶臭数占比\n    numbers = re.findall(r'\\d+', expr_str)\n    stench_set = set(ALL_POOL_MEGA)\n    nums_int = [int(n) for n in numbers]\n    if nums_int:\n        ratio = sum(1 for n in nums_int if n in stench_set) / len(nums_int)\n        if ratio > 0.7:\n            score += 2\n\n    # 等级转换\n    if score <= 2:\n        level = max(1, score)\n        emoji = \"🫵\"\n        label = \"不够臭啊\"\n    elif score <= 5:\n        level = max(3, score - 1)\n        emoji = \"💨\"\n        label = \"微微发臭\"\n    elif score <= 8:\n        level = score - 1\n        emoji = \"🤢\"\n        label = \"有点味道了\"\n    elif score <= 12:\n        level = score - 4\n        emoji = \"💩\"\n        label = \"恶臭来袭\"\n    elif score <= 16:\n        level = 9\n        emoji = \"🔥\"\n        label = \"非常恶臭\"\n    else:\n        level = 10\n        emoji = \"🏆\"\n        label = \"究极恶臭！\"\n\n    return level, emoji, label, score\n\n\ndef select_top_expressions(all_exprs, max_count=5):\n    \"\"\"按恶臭等级排序，去重后选择前 max_count 个\"\"\"\n    if not all_exprs:\n        return []\n\n    scored = []\n    seen_fingerprints = set()\n\n    for expr, val, strategy in all_exprs:\n        level, emoji, label, score = rate_expression(expr)\n\n        # 指纹去重：排序后的数字列表\n        nums = re.findall(r'\\d+', expr)\n        fingerprint = tuple(sorted(int(n) for n in nums))\n        if fingerprint in seen_fingerprints:\n            continue\n        seen_fingerprints.add(fingerprint)\n\n        scored.append((expr, val, strategy, level, emoji, label, score))\n\n    # 排序：等级降序 → 评分降序 → 表达式短优先\n    scored.sort(key=lambda x: (-x[3], -x[6], len(x[0])))\n    return scored[:max_count]\n\n\n# =====================================================================\n# 第六节：主流程\n# =====================================================================\n\ndef generate(target):\n    \"\"\"\n    主入口：对目标数字执行恶臭拆解，返回格式化的输出行列表。\n    \"\"\"\n    results_lines = []\n\n    # 特殊处理：本身就是 114514\n    if target == 114514:\n        results_lines.append(f\"数字 114514 的恶臭拆解：\")\n        results_lines.append(\"\")\n        results_lines.append(\"🤢 完美！114514 本身就是最臭的数字！\")\n        results_lines.append(\"恶臭等级：10/10 🏆 究极恶臭！\")\n        results_lines.append(\"\")\n        results_lines.append(\"💩 其他恶臭组合：\")\n        results_lines.append(\"114514 = 114000 + 514\")\n        results_lines.append(\"114514 = 114 × 1000 + 514\")\n        results_lines.append(\"114514 = 514 × 222 + 114 + 114 − 5 + 1 − 1 + 4\")\n        results_lines.append(\"\")\n        results_lines.append(\"🫵 你就是传说中的人？！\")\n        return results_lines\n\n    # 运行所有搜索策略\n    exprs = search_all_strategies(target)\n\n    # 超大数直接走学院派路线（10亿以上）\n    if target > 1_000_000_000:\n        return generate_academic(target)\n\n    if not exprs:\n        return generate_academic(target)\n\n    top5 = select_top_expressions(exprs, 5)\n\n    if not top5:\n        return generate_academic(target)\n\n    # 检测最佳表达式是否为恒等式偷懒\n    best_expr, _, _, best_level, best_emoji, best_label, _ = top5[0]\n    if best_level <= 6 and re.search(r'\\(\\d+ × target\\) ÷ \\d+', best_expr.replace(str(target), 'target')):\n        return generate_academic(target)\n\n    results_lines.append(f\"🤢 数字 {target} 的恶臭拆解：\")\n    results_lines.append(\"\")\n\n    # 最佳恶臭\n    results_lines.append(\"📿 最佳恶臭：\")\n    results_lines.append(f\"{target} = {best_expr}\")\n    results_lines.append(f\"恶臭等级：{best_level}/10 {best_emoji} {best_label}\")\n    results_lines.append(\"\")\n\n    # 其他恶臭组合\n    if len(top5) > 1:\n        results_lines.append(\"💩 其他恶臭组合：\")\n        for item in top5[1:]:\n            expr, _, _, _, _, _, _ = item\n            results_lines.append(f\"{target} = {expr}\")\n        results_lines.append(\"\")\n\n    results_lines.append(\"--- \")\n    results_lines.append(\"🫵 你也是恶臭人了！\")\n\n    return results_lines\n\n\ndef _recurse_stench(n, depth=0):\n    \"\"\"递归恶臭拆解：用114514反复取模拆分，直到每个部分都小于114514可直拆\"\"\"\n    if depth > 3:\n        return str(n)\n    if n < 114514:\n        # 小数字尝试用DFS拆\n        if n in ALL_POOL or n < 20:\n            return str(n)\n        # 用 514/114 拆一层\n        for divisor in [514, 114, 14514]:\n            if n > divisor:\n                k = n // divisor\n                r = n % divisor\n                if r != 0 and not has_digit_zero(r):\n                    k_part = _recurse_stench(k, depth+1)\n                    r_part = _recurse_stench(r, depth+1)\n                    return f\"{divisor} × {k_part} + {r_part}\"\n        return str(n)\n    \n    k = n // 114514\n    r = n % 114514\n    \n    if r == 0 or has_digit_zero(r):\n        # 余数有0，换个拆法\n        k = n // 514\n        r = n % 514\n        if r != 0 and not has_digit_zero(r):\n            k_part = _recurse_stench(k, depth+1)\n            r_part = _recurse_stench(r, depth+1)\n            return f\"514 × {k_part} + {r_part}\"\n        return str(n)\n    \n    k_part = _recurse_stench(k, depth+1)\n    r_part = _recurse_stench(r, depth+1)\n    return f\"114514 × {k_part} + {r_part}\"\n\n\ndef generate_academic(target):\n    \"\"\"学院派兜底：递归用114514反复取模拆解大数\"\"\"\n    results_lines = []\n    results_lines.append(f\"🤢 数字 {target} 的恶臭拆解（学院派）：\")\n    results_lines.append(\"\")\n\n    expr = _recurse_stench(target)\n    level, emoji, label, _ = rate_expression(expr)\n    results_lines.append(\"📿 最佳恶臭（学院派）：\")\n    results_lines.append(f\"{target} = {expr}\")\n    results_lines.append(f\"恶臭等级：{level}/10 {emoji} {label}\")\n    results_lines.append(\"\")\n\n    results_lines.append(\"--- \")\n    results_lines.append(\"🫵 你也是恶臭人了！\")\n\n    return results_lines\n\n\ndef main():\n    if len(sys.argv) < 2:\n        print(\"用法: python3 generate.py <数字>\")\n        print(\"示例: python3 generate.py 20070521\")\n        sys.exit(1)\n\n    try:\n        target = int(sys.argv[1])\n    except ValueError:\n        print(\"❌ 请输入有效的正整数\")\n        sys.exit(1)\n\n    if target <= 0:\n        print(\"🤢 请输入正整数。0 和负数不能进行恶臭拆解。\")\n        sys.exit(1)\n\n    lines = generate(target)\n    for line in lines:\n        print(line)\n\n\nif __name__ == \"__main__\":\n    main()\n"}],"isError":false,"timestamp":1780248390197}}
